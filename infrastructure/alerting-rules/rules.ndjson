{"rule_id":"vm-high-cpu-sustained","name":"VM: CPU > 85% for 5min","type":"metrics.threshold","params":{"criteria":[{"metric":"system.cpu.total.pct","comparator":">","threshold":[0.85],"timeSize":5,"timeUnit":"m","aggType":"avg"}]},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"threshold_met"}]}
{"rule_id":"vm-disk-space-critical","name":"VM: Disk free < 10%","type":"metrics.threshold","params":{"criteria":[{"metric":"system.filesystem.free_pct","comparator":"<","threshold":[0.10],"timeSize":5,"timeUnit":"m","aggType":"last"}]},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"threshold_met"}]}
{"rule_id":"vm-memory-pressure","name":"VM: Available memory < 500MB","type":"metrics.threshold","params":{"criteria":[{"metric":"system.memory.actual.free","comparator":"<","threshold":[524288000],"timeSize":5,"timeUnit":"m","aggType":"avg"}]},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"threshold_met"}]}
{"rule_id":"pg-connection-pool-exhaustion","name":"Postgres: connections > 80% of max","type":"esQuery","params":{"esql":"FROM metrics-postgresql.activity-* | EVAL pct = pg.activity.count / pg.activity.max_connections | WHERE pct > 0.8"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"pg-cache-hit-degradation","name":"Postgres: cache hit ratio < 95%","type":"esQuery","params":{"esql":"FROM metrics-postgresql.database-* | EVAL hit_ratio = pg.database.blocks.hit / (pg.database.blocks.hit + pg.database.blocks.read) | WHERE hit_ratio < 0.95"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"redis-memory-approaching-max","name":"Redis: memory > 85% of maxmemory","type":"esQuery","params":{"esql":"FROM metrics-redis.info-* | EVAL mem_pct = redis.info.memory.used.bytes / redis.info.memory.max.bytes | WHERE mem_pct > 0.85"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"redis-high-eviction-rate","name":"Redis: eviction rate above baseline","type":"esQuery","params":{"esql":"FROM metrics-redis.info-* | STATS evictions = MAX(redis.info.stats.evicted_keys) BY BUCKET(@timestamp, 5 minute) | WHERE evictions > baseline_threshold"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"nginx-5xx-error-spike","name":"NGINX: 5xx rate > 5% over 2min","type":"esQuery","params":{"esql":"FROM logs-nginx.access-* | STATS total = COUNT(*), errors = COUNT(*) WHERE status >= 500 BY BUCKET(@timestamp, 2 minute) | EVAL rate = errors / total | WHERE rate > 0.05"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"nginx-upstream-unavailable","name":"NGINX: backend 502/503 detected","type":"esQuery","params":{"esql":"FROM logs-nginx.access-* | WHERE status == 502 OR status == 503"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"nginx-ssl-cert-expiring","name":"NGINX: SSL cert expires within 14 days","type":"metrics.threshold","params":{"criteria":[{"metric":"nginx_ingress_controller_ssl_expire_time_seconds","comparator":"<","threshold":[1209600],"aggType":"min"}]},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"threshold_met"}]}
{"rule_id":"network-unexpected-egress","name":"Network: egress to non-allowlisted external IP","type":"esQuery","params":{"esql":"FROM logs-network_flow-* | WHERE verdict == \"FORWARDED\" AND destination.ip NOT IN (allowlist) | STATS egress_count = COUNT(*) BY destination.ip, source.namespace | WHERE egress_count > 5"},"consumer":"infrastructure","actions":[{"connector":"webhook-generic","group":"query_matched"}]}
{"rule_id":"apm-error-rate-anomaly","name":"APM: service error rate anomaly (fallback threshold if no ML license)","type":"apm.transaction_error_rate","params":{"threshold":10,"windowSize":5,"windowUnit":"m"},"consumer":"apm","actions":[{"connector":"webhook-generic","group":"threshold_met"}]}
